# =============================================================================
# .dockerignore — MagixPromotion
# =============================================================================
# Esclude file inutili/sensibili dal context Docker per build veloci e sicuri.
# =============================================================================

# Python
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
htmlcov
.coverage
.venv
venv

# Node (ricostruito nello stage frontend-build)
frontend/node_modules
frontend/.vite
node_modules

# IDE
.vscode
.idea
*.swp
*.swo
*~

# Git
.git
.gitignore

# Database / schedule locali
db.sqlite3
celerybeat-schedule
celerybeat-schedule.db

# Docker compose (non servono dentro il container)
deploy/docker-compose*.yml
deploy/live/

# Docs & materiali
*.md
!README.md
docs/
tasks/
materiale/
scripts/
REPORT-*.md

# Media (montato come volume in prod)
media/

# Tests (non servono in produzione)
tests/
frontend/src/__tests__/

# Environment (segreti — mai nel container!)
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
